{
  "name": "sistema-cargas-trabajo-backend",
  "version": "1.0.0",
  "description": "Backend para Sistema de Gestión de Cargas de Trabajo",
  "main": "dist/index.js",
  "scripts": {
    "dev": "nodemon --exec ts-node src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "seed": "ts-node src/database/seed.ts",
    "seed:real": "ts-node src/database/seedReal.ts",
    "seed:excel": "ts-node src/database/seedRealWithExcelData.ts",
    "seed:simple": "ts-node src/database/seedExcelSimple.ts",
    "seed:directo": "node src/database/seedDirecto.js",
    "setup": "node src/database/setupCompleto.js",
    "start:demo": "node inicio-backend.js",
    "start:integrado": "ts-node servidor-integrado.ts",
    "start:simple": "node servidor-integrado-simple.js",
    "start:production": "node servidor-integrado-simple.js",
    "migrate": "ts-node src/database/migrate.ts",
    "backup": "ts-node src/database/backup.ts",
    "lint": "eslint src/**/*.ts",
    "lint:fix": "eslint src/**/*.ts --fix",
    "type-check": "tsc --noEmit",
    "clean": "rm -rf dist",
    "prebuild": "npm run clean && npm run type-check",
    "postinstall": "npm run build",
    "docker:build": "docker build -t cargas-trabajo-backend .",
    "docker:run": "docker run -p 3001:3001 cargas-trabajo-backend"
  },
  "keywords": [
    "cargas-trabajo",
    "backend",
    "api",
    "typescript",
    "express"
  ],
  "author": "Sistema Cargas Trabajo Team",
  "license": "MIT",
  "dependencies": {
    "@types/bcrypt": "^6.0.0",
    "axios": "^1.11.0",
    "bcrypt": "^6.0.0",
    "bcryptjs": "^2.4.3",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.0",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "helmet": "^7.1.0",
    "joi": "^17.11.0",
    "jsonwebtoken": "^9.0.2",
    "mysql2": "^3.14.2",
    "sqlite3": "^5.1.6",
    "uuid": "^9.0.1",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jest": "^29.5.8",
    "@types/jsonwebtoken": "^9.0.5",
    "@types/node": "^20.8.10",
    "@types/uuid": "^9.0.7",
    "@types/xlsx": "^0.0.36",
    "jest": "^29.7.0",
    "nodemon": "^3.0.1",
    "ts-node": "^10.9.1",
    "typescript": "^5.2.2"
  }
}
